# Credenciais do projeto Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Token da consulta de placa (apiplacas.com.br / wdapi2)
APIPLACAS_TOKEN=seu_token_aqui

# Verificação de identidade (facematch documento x selfie)
# Service role do Supabase — marca o perfil como verificado (SÓ server-side)
SUPABASE_SERVICE_ROLE_KEY=service_role_key_aqui
# URL pública do serviço DeepFace (ver services/face-verify/README.md)
FACE_VERIFY_URL=https://catire-face-verify.exemplo.run.app
# Mesmo segredo configurado no serviço de facematch
FACE_VERIFY_TOKEN=um_segredo_forte
